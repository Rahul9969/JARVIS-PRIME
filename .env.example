# ═══════════════════════════════════════════════════════
#  JARVIS-PRIME Configuration
#  Put your API keys here and rename to .env
# ═══════════════════════════════════════════════════════

# ──────── LLM Providers (FREE) ────────

# Groq (Free tier: 14,400 req/day)
# Get your key: https://console.groq.com/keys
JARVIS_GROQ_API_KEY=

# Google Gemini (Free tier: 1,500 req/day)
# Get your key: https://aistudio.google.com/apikey
JARVIS_GEMINI_API_KEY=

# Ollama (100% Local, unlimited)
# Download: https://ollama.com/download
# Then run: ollama pull qwen3:1.7b
# No API key needed - runs on localhost:11434
JARVIS_OLLAMA_MODEL=qwen3:1.7b

# ──────── System Settings ────────
JARVIS_WAKE_WORD=jarvis
JARVIS_TTS_RATE=185
JARVIS_LOG_LEVEL=INFO
